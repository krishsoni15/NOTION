FROM node:20-alpine

WORKDIR /app

# Install dependencies needed for Convex/Next.js
RUN apk add --no-cache libc6-compat

# Copy package files
COPY package.json package-lock.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

# Expose ports for Next.js and Convex
EXPOSE 3000

# Start development server
CMD ["npm", "run", "dev:all"]
